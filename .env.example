###############################################################################
# SaleH SaaS 4.0 - إعدادات البيئة
# صُنع بفخر في مكة المكرمة، المملكة العربية السعودية
#
# انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
#
# IMPORTANT: غيّر جميع القيم أدناه قبل التشغيل في الإنتاج
###############################################################################

# ── قاعدة البيانات PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=salehsaas
POSTGRES_USER=salehsaas
# غيّر كلمة المرور هذه - استخدم كلمة مرور قوية لا تقل عن 24 حرفاً
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_HERE

# ── Open WebUI - الواجهة الرئيسية ────────────────────────────────────────────
WEBUI_PORT=3000
# مفتاح سري لـ JWT - يجب أن يكون 64 حرفاً hex على الأقل
WEBUI_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_KEY_HERE
ENABLE_SIGNUP=true

# ── Pipelines - المعالج القانوني ──────────────────────────────────────────────
PIPELINES_PORT=9099
# مفتاح API للـ Pipelines - 32 حرفاً hex
PIPELINES_KEY=REPLACE_WITH_32_CHAR_HEX_KEY_HERE

# ── Ollama - نموذج الذكاء الاصطناعي (يعمل على Windows) ──────────────────────
# Ollama يعمل على Windows مباشرة - لا تغيّر هذا
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_MODEL=llama3.1:latest
EMBEDDING_MODEL=nomic-embed-text:latest

# ── n8n - الأتمتة والنشر ──────────────────────────────────────────────────────
N8N_PORT=5678
N8N_USER=admin
# كلمة مرور n8n - لا تقل عن 20 حرفاً
N8N_PASSWORD=REPLACE_WITH_STRONG_N8N_PASSWORD
# مفتاح تشفير n8n - يجب أن يبقى ثابتاً بعد أول تشغيل
N8N_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_KEY_HERE
# مفتاح n8n Public API - للاستخدام مع n8n_builder MCP tool
N8N_API_KEY=salehsaas-n8n-api-key

# ── mcpo - MCP-to-OpenAPI Proxy ───────────────────────────────────────────────
MCPO_PORT=8020
# مفتاح API لـ mcpo - يُستخدم في Open WebUI عند إضافة الأدوات
MCPO_API_KEY=salehsaas-mcpo-key

# ── Code Server - بيئة التطوير ────────────────────────────────────────────────
CODE_SERVER_PORT=8443
# كلمة مرور Code Server
CODE_SERVER_PASSWORD=REPLACE_WITH_STRONG_CODE_PASSWORD

# ── ChromaDB - قاعدة البيانات المتجهية ───────────────────────────────────────
CHROMADB_PORT=8010

###############################################################################
# تعليمات توليد كلمات مرور قوية (PowerShell):
#
#   [System.Web.Security.Membership]::GeneratePassword(32, 4)
#
# أو استخدم Python:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ملاحظات مهمة:
# - N8N_ENCRYPTION_KEY يجب أن يبقى ثابتاً بعد أول تشغيل - لا تغيّره أبداً
# - Ollama يجب أن يكون مثبتاً على Windows ويعمل على المنفذ 11434
# - تأكد من تثبيت النماذج: ollama pull llama3.1 && ollama pull nomic-embed-text
# - بعد التشغيل، افتح Open WebUI على: http://localhost:3000
# - Code Server على: http://localhost:8443
# - n8n على: http://localhost:5678
# - لإضافة أدوات MCP في Open WebUI:
#     Settings → Tools → Add Tool → URL: http://localhost:8020
#     API Key: salehsaas-mcpo-key
###############################################################################
