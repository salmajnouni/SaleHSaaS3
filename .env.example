###############################################################################
# SaleHSaaS 3.0 - Environment Variables Template
# 🕋 صُنع بفخر في مكة المكرمة، المملكة العربية السعودية
# Made with pride in Makkah Al-Mukarramah, Saudi Arabia
#
# انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل
# Copy this file to .env and update values before running
###############################################################################

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=salehsaas
POSTGRES_USER=salehsaas_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_456!

# ── AI Engine ─────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=2
# Default model to pull on startup (e.g., llama3, mistral, qwen2)
DEFAULT_MODEL=llama3

# ── Open WebUI ────────────────────────────────────────────────────────────────
OPEN_WEBUI_PORT=3000
WEBUI_SECRET_KEY=CHANGE_THIS_WEBUI_SECRET_KEY_789!
ENABLE_SIGNUP=false

# ── n8n Automation ────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=CHANGE_THIS_N8N_PASSWORD_101!
N8N_ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_ENCRYPTION_KEY_HERE

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── SearXNG Search ────────────────────────────────────────────────────────────
SEARXNG_PORT=8080
SEARXNG_SECRET=CHANGE_THIS_SEARXNG_SECRET_202!

# ── Arabic Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=CHANGE_THIS_DASHBOARD_SECRET_303!
FLASK_DEBUG=false

# ── Code Server (Dev Studio) ──────────────────────────────────────────────────
CODE_SERVER_PORT=8443
CODE_SERVER_PASSWORD=CHANGE_THIS_CODE_SERVER_PASSWORD!

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD_404!

# ── External Database Connections (Optional) ──────────────────────────────────
# SQL Server
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_DB=

# MySQL
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# Oracle
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_SERVICE=

# SAP OData
SAP_BASE_URL=
SAP_USER=
SAP_PASSWORD=
