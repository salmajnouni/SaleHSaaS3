###############################################################################
# SaleH SaaS 4.0 - إعدادات البيئة
# صُنع بفخر في مكة المكرمة، المملكة العربية السعودية
#
# انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
#
# IMPORTANT: غيّر جميع القيم أدناه قبل التشغيل في الإنتاج
###############################################################################

# ── قاعدة البيانات PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=salehsaas
POSTGRES_USER=salehsaas
# غيّر كلمة المرور هذه - استخدم كلمة مرور قوية لا تقل عن 24 حرفاً
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_HERE

# ── Open WebUI - الواجهة الرئيسية ────────────────────────────────────────────
WEBUI_PORT=3000
# مفتاح سري لـ JWT - يجب أن يكون 64 حرفاً hex على الأقل
WEBUI_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_KEY_HERE
ENABLE_SIGNUP=true

# ── Pipelines - المعالج القانوني ──────────────────────────────────────────────
PIPELINES_PORT=9099
# مفتاح API للـ Pipelines / Knowledge Watcher / Open WebUI integration
PIPELINES_API_KEY=REPLACE_WITH_PIPELINES_API_KEY_HERE

# مفتاح WebUI API إذا احتاجه n8n أو تكاملات داخلية أخرى
WEBUI_API_KEY=REPLACE_WITH_WEBUI_API_KEY_HERE

# ── Ollama - نموذج الذكاء الاصطناعي (يعمل على Windows) ──────────────────────
# Ollama يعمل على Windows مباشرة - لا تغيّر هذا
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_MODEL=llama3.1:latest
EMBEDDING_MODEL=qwen3-embedding:0.6b

# ── n8n - الأتمتة والنشر ──────────────────────────────────────────────────────
N8N_PORT=5678
N8N_USER=admin
# كلمة مرور n8n - لا تقل عن 20 حرفاً
N8N_PASSWORD=REPLACE_WITH_STRONG_N8N_PASSWORD
# بريد الدخول الآلي المستخدم من pipelines عند الحاجة
N8N_LOGIN_EMAIL=salmajnouni@gmail.com
# مفتاح n8n Public API
N8N_API_KEY=REPLACE_WITH_N8N_API_KEY_HERE
# توكن الـ external runners بين n8n و task_runners
N8N_RUNNERS_AUTH_TOKEN=REPLACE_WITH_RUNNERS_AUTH_TOKEN_HERE

# ── أسرار خدمات مساندة ───────────────────────────────────────────────────────
SEARXNG_SECRET=REPLACE_WITH_SEARXNG_SECRET_HERE
OPEN_TERMINAL_API_KEY=REPLACE_WITH_OPEN_TERMINAL_API_KEY_HERE
CRAWL4AI_API_TOKEN=REPLACE_WITH_CRAWL4AI_API_TOKEN_HERE

# ── mcpo (Cancelled) ──────────────────────────────────────────────────────────
# خدمة mcpo ملغاة حاليًا في هذا المشروع.
# تُترك القيم التالية لأغراض تاريخية فقط ولا يجب استخدامها في التشغيل الحالي.
MCPO_PORT=8020
MCPO_API_KEY=salehsaas-mcpo-key

# ── Code Server (Legacy/Optional) ────────────────────────────────────────────
CODE_SERVER_PORT=8443
# كلمة مرور Code Server (اختياري إذا تم تفعيل Dev Studio)
CODE_SERVER_PASSWORD=REPLACE_WITH_STRONG_CODE_PASSWORD

# ── ChromaDB - قاعدة البيانات المتجهية الحية ─────────────────────────────────
CHROMADB_PORT=8010

# ── المجلس الاستشاري الداخلي (اختياري) ──────────────────────────────────────
# إذا أردت أن ترسل شاشة المجلس الطلبات مباشرة إلى n8n أو مسار Webhook آخر، ضع الرابط هنا
COUNCIL_WEBHOOK_URL=
# استخدم هذا فقط إذا كان الـ webhook يتطلب Bearer token
COUNCIL_WEBHOOK_TOKEN=
# أمان احترافي: افتراضيًا APIs المجلس محلية فقط (127.0.0.1)
COUNCIL_ALLOW_REMOTE=false
# حد أقصى لطول موضوع الدراسة
COUNCIL_MAX_TOPIC_CHARS=1200
# منع التكرار السريع لنفس الطلب (بالثواني)
COUNCIL_REQUEST_COOLDOWN_SEC=30

# ── تيليجرام (اختياري للمجلس الاستشاري) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
SALEH_TELEGRAM_CHAT_ID=

###############################################################################
# تعليمات توليد كلمات مرور قوية (PowerShell):
#
#   [System.Web.Security.Membership]::GeneratePassword(32, 4)
#
# أو استخدم Python:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ملاحظات مهمة:
# - N8N_ENCRYPTION_KEY يجب أن يبقى ثابتاً بعد أول تشغيل - لا تغيّره أبداً
# - Ollama يجب أن يكون مثبتاً على Windows ويعمل على المنفذ 11434
# - تأكد من تثبيت النماذج المطلوبة حسب التشغيل الحالي
# - نموذج التضمين الحي: qwen3-embedding:0.6b
# - بعد التشغيل، افتح Open WebUI على: http://localhost:3000
# - Code Server (اختياري/Legacy): http://localhost:8443
# - mcpo: ملغي حاليًا (لا endpoint تشغيلي)
# - n8n على: http://localhost:5678
# - مسار MCP عبر mcpo ملغي حاليًا.
###############################################################################
