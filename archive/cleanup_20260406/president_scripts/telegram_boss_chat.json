    {
      "parameters": {
        "jsCode": "const chatId = $('🧠 Route Update').first().json.chatId;\nconst response = $json;\n\nlet answer = '';\nif (response.choices && response.choices.length > 0) {\n  answer = response.choices[0].message?.content || '';\n} else if (response.message?.content) {\n  answer = response.message.content;\n} else {\n  answer = '\\u26A0\\uFE0F \\u0644\\u0645 \\u0623\\u062A\\u0645\\u0643\\u0646 \\u0645\\u0646 \\u0627\\u0644\\u062D\\u0635\\u0648\\u0644 \\u0639\\u0644\\u0649 \\u0631\\u062F';\n}\n\n// Trim if too long for Telegram (4096 char limit)\nif (answer.length > 4000) {\n  answer = answer.substring(0, 4000) + '\\n\\n... (\\u062A\\u0645 \\u0627\\u0642\\u062A\\u0637\\u0627\\u0639 \\u0627\\u0644\\u0631\\u062F)';\n}\n\nreturn [{ json: { chatId, answer } }];\n"
      },
