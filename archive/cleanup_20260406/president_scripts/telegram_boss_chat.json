    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json || {};\n\n// Determine update type\nif (body.callback_query) {\n  // callback_query from inline buttons\n  const cb = body.callback_query;\n  const callbackData = cb.data || '';\n  const callbackQueryId = cb.id || '';\n  const chatId = String(cb?.message?.chat?.id || '');\n  const allowedChatId = String($vars.SALEH_TELEGRAM_CHAT_ID || '');\n\n  if (!allowedChatId || chatId !== allowedChatId) {\n    return [{ json: { type: 'callback', chatId, callbackQueryId, message: '\\u26D4 \\u063A\\u064A\\u0631 \\u0645\\u0635\\u0631\\u062D' } }];\n  }\n\n  if (!callbackData.startsWith('COUNCIL_')) {\n    return [{ json: { type: 'skip' } }];\n  }\n\n  const [rawDecision, sessionId] = callbackData.split('::');\n  const map = {\n    COUNCIL_APPROVE: { status: 'approved', label: '\\u2705 \\u062A\\u0645 \\u0627\\u0639\\u062A\\u0645\\u0627\\u062F \\u0627\\u0644\\u062A\\u0648\\u0635\\u064A\\u0629' },\n    COUNCIL_REJECT: { status: 'rejected', label: '\\u274C \\u062A\\u0645 \\u0631\\u0641\\u0636 \\u0627\\u0644\\u062A\\u0648\\u0635\\u064A\\u0629' },\n    COUNCIL_RESTUDY: { status: 'restudy', label: '\\uD83D\\uDD04 \\u0625\\u0639\\u0627\\u062F\\u0629 \\u062F\\u0631\\u0627\\u0633\\u0629' }\n  };\n  const decisionInfo = map[rawDecision] || { status: 'unknown', label: '\\u0642\\u0631\\u0627\\u0631 \\u063A\\u064A\\u0631 \\u0645\\u0639\\u0631\\u0648\\u0641' };\n\n  return [{ json: {\n    type: 'callback',\n    chatId,\n    callbackQueryId,\n    message: decisionInfo.label + '\\n\\n\\uD83D\\uDD16 \\u0627\\u0644\\u062C\\u0644\\u0633\\u0629: ' + (sessionId || '') + '\\n\\uD83D\\uDD52 ' + new Date().toISOString()\n  }}];\n} else if (body.message && body.message.text) {\n  // Regular text message\n  const msg = body.message;\n  const chatId = String(msg.chat.id);\n  const allowedChatId = String($vars.SALEH_TELEGRAM_CHAT_ID || '');\n\n  if (!allowedChatId || chatId !== allowedChatId) {\n    return [{ json: { type: 'unauthorized', chatId } }];\n  }\n\n  const text = msg.text;\n  const firstName = msg.from?.first_name || '';\n\n  return [{ json: {\n    type: 'message',\n    chatId,\n    userText: text,\n    firstName\n  }}];\n} else {\n  return [{ json: { type: 'skip' } }];\n}\n"
      },
      "id": "tb-0002",
      "name": "🧠 Route Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
