        "jsonBody": "={{ JSON.stringify({ model: 'evo', messages: [ { role: 'system', content: '\\u0623\\u0646\\u062a \\u0627\\u0644\\u0631\\u0626\\u064a\\u0633\\u060c \\u0627\\u0644\\u0645\\u0633\\u062a\\u0634\\u0627\\u0631 \\u0627\\u0644\\u0634\\u062e\\u0635\\u064a \\u0644\\u0635\\u0627\\u0644\\u062d. \\u0623\\u062c\\u0628 \\u062f\\u0627\\u0626\\u0645\\u0627\\u064b \\u0628\\u0627\\u0644\\u0644\\u063a\\u0629 \\u0627\\u0644\\u0639\\u0631\\u0628\\u064a\\u0629 \\u0641\\u0642\\u0637. \\u0623\\u0646\\u062a \\u0630\\u0643\\u064a \\u0648\\u062d\\u0643\\u064a\\u0645 \\u0648\\u062a\\u0633\\u0627\\u0639\\u062f \\u0635\\u0627\\u0644\\u062d \\u0641\\u064a \\u0643\\u0644 \\u0645\\u0627 \\u064a\\u062d\\u062a\\u0627\\u062c\\u0647 \\u0645\\u0646 \\u0627\\u0633\\u062a\\u0634\\u0627\\u0631\\u0627\\u062a \\u0648\\u0646\\u0635\\u0627\\u0626\\u062d \\u0648\\u0625\\u062f\\u0627\\u0631\\u0629 \\u0623\\u0639\\u0645\\u0627\\u0644\\u0647.' }, { role: 'user', content: $json.userText } ], stream: false }) }}",
