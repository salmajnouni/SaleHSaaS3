    "المقاول": {
      "id": "T001",
      "category": "نظام المنافسات والمشتريات الحكومية",
      "has_conflict": true,
      "conflict_note": "يختلف تعريف المقاول بين نظام العمل ونظام المنافسات",
      "definitions": [
        {
          "context": "نظام المنافسات والمشتريات الحكومية",
          "text": "الشخص الطبيعي أو الاعتباري الذي يمارس نشاط المقاولات لتنفيذ أعمال البناء والتشييد والصيانة.",
          "source_law": "نظام المنافسات والمشتريات الحكومية",
          "article": "المادة الأولى - التعريفات",
          "decree": "المرسوم الملكي م/128 وتعديلاته",
          "year": "1440هـ"
        },
        {
          "context": "نظام العمل",
          "text": "كل شخص طبيعي أو اعتباري، يستخدم عاملاً أو أكثر لقاء أجر، ويُعدّ صاحب عمل في تطبيق أحكام هذا النظام.",
          "source_law": "نظام العمل",
          "article": "المادة الثانية - التعريفات",
          "decree": "المرسوم الملكي م/51",
          "year": "1426هـ"
        },
        {
          "context": "نظام البناء والتشييد",
          "text": "المرخص له بتنفيذ أعمال البناء والتشييد والهدم وفق الاشتراطات الفنية المعتمدة.",
          "source_law": "نظام البناء",
          "article": "المادة الأولى",
          "decree": "المرسوم الملكي م/101",
          "year": "1441هـ"
        }
      ],
      "related_terms": ["صاحب العمل", "المتعاقد", "المقاولة من الباطن"],
      "tags": ["مقاولات", "عمل", "مشتريات"]
    },
    "العقد": {
      "id": "T002",
      "category": "نظام المنافسات والمشتريات الحكومية",
      "has_conflict": true,
      "conflict_note": "يختلف تعريف العقد بين الأنظمة المختلفة من حيث الأطراف والالتزامات",
      "definitions": [
        {
          "context": "نظام المنافسات والمشتريات الحكومية",
          "text": "اتفاق مكتوب بين جهة حكومية ومتعاقد معها، لتأمين الأصناف أو تنفيذ الأعمال أو الخدمات وفق الشروط والمواصفات المحددة.",
          "source_law": "نظام المنافسات والمشتريات الحكومية",
          "article": "المادة الأولى",
          "decree": "المرسوم الملكي م/128",
          "year": "1440هـ"
        },
        {
          "context": "نظام العمل",
          "text": "عقد مبرم بين صاحب عمل وعامل، يتعهد العامل بموجبه أن يعمل تحت إدارة صاحب العمل أو إشرافه مقابل أجر.",
          "source_law": "نظام العمل",
          "article": "المادة الخمسون",
          "decree": "المرسوم الملكي م/51",
          "year": "1426هـ"
        },
        {
          "context": "نظام الشركات",
          "text": "الاتفاق الذي يلتزم بموجبه شخصان أو أكثر بالمساهمة في مشروع مشترك بتقديم حصة من مال أو عمل أو غير ذلك، واقتسام ما قد ينشأ عن هذا المشروع من ربح أو خسارة.",
          "source_law": "نظام الشركات",
          "article": "المادة الثانية",
          "decree": "المرسوم الملكي م/3",
          "year": "1437هـ"
        }
      ],
      "related_terms": ["العقد الإداري", "عقد العمل", "عقد المقاولة"],
      "tags": ["عقود", "التزامات", "مشتريات", "عمل"]
    },
