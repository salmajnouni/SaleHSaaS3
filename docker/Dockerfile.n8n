FROM n8nio/n8n:2.14.2

# Install Python 3 for N8N internal Python task runner
USER root
RUN apt-get update && \
    apt-get install -y python3 python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Verify installation
RUN python3 --version && pip3 --version

# Return to n8n user
USER node
