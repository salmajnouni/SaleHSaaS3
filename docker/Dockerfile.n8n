FROM n8nio/n8n:2.14.2
# NOTE: n8nio/n8n:2.14.2 uses Docker Hardened Image (Alpine).
# Hardened images strip package managers (apk/apt-get) for security.
# Python 3 CANNOT be installed in this image.
# n8n 2.14.x always emits "Failed to start Python task runner" at startup.
# There is no env var to suppress this warning (N8N_RUNNERS_ENABLED is deprecated).
# JS runner is registered and fully functional.
# This warning is accepted as a known limitation and filtered in ops_detect_deviations.ps1.
