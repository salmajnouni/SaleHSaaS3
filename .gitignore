# Environment variables (NEVER commit these)
.env
*.env.local
*.env.production

# Data directories
data/uploads/*
data/exports/*
data/incoming/*
data/processed/*
data/failed/*
!data/uploads/.gitkeep
!data/exports/.gitkeep
!data/incoming/.gitkeep
!data/processed/.gitkeep
!data/failed/.gitkeep

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Node.js
node_modules/
npm-debug.log*

# Knowledge folders - keep structure, ignore content
knowledge_inbox/*
knowledge_processed/*
knowledge_processing/*
knowledge_failed/*
knowledge_archive/*
!knowledge_inbox/.gitkeep
!knowledge_processed/.gitkeep
!knowledge_processing/.gitkeep
!knowledge_failed/.gitkeep
!knowledge_archive/.gitkeep

# Docker volumes (local only)
postgres_data/
redis_data/
ollama_models/
chromadb_data/
n8n_data/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Backups
backups/
*.bak
*.backup

# Temporary files
tmp/
temp/
*.tmp

# Security
*.pem
*.key
*.crt
*.p12
secrets/

# Model cache / embeddings (large binaries)
**/cache/embedding/
**/models--*/
*.safetensors
*.onnx

# Vector DB binary files
**/vector_db/
**/chroma_data/

# n8n temp exports
n8n/workflows/_tmp_*
n8n/workflows/*import*
n8n/workflows/sample_export.json

# Archive large binaries
archive/**/*.bin
archive/**/vector_db/
archive/**/cache/

# Runtime databases
**/webui.db
**/webui.db-journal
